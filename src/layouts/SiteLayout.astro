---
import '../styles/global.css';
import '../styles/pilot.css';
import '../styles/integrations.css';
interface Props { title: string; description: string; canonical?: string; }
const { title, description, canonical = Astro.url.pathname } = Astro.props;
const canonicalUrl = new URL(canonical, Astro.site);
const nav = [
  ['/platform/', 'Platform'], ['/how-it-works/', 'How it works'], ['/pricing/', 'Pricing'],
  ['/faq/', 'FAQ'], ['/blog/', 'Blog'],
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="theme-color" content="#070907" />
    <link rel="icon" type="image/avif" href="/favicon.avif" sizes="32x32" />
    <link rel="icon" type="image/avif" href="/favicon.avif" sizes="192x192" />
    <link rel="apple-touch-icon" href="/favicon.avif" />
    <title>{title}</title>
    <script is:inline>document.documentElement.classList.add('has-js');</script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org', '@type': 'Organization', name: 'Mault', url: 'https://mault.ai',
      sameAs: ['https://linkedin.com/company/mault/', 'https://x.com/maultai', 'https://instagram.com/mault_ai/'],
    })} />
  </head>
  <body>
    <div class="splash" data-splash aria-hidden="true">
      <div class="splash-inner">
        <div class="splash-brand"><img class="brand-logo brand-logo-splash" src="/assets/mault-logo.png" alt="Mault" width="903" height="313" /></div>
        <div class="splash-readout"><span>Initializing governance</span><strong data-splash-count>0%</strong></div>
        <div class="splash-track"><i data-splash-bar></i></div>
      </div>
    </div>
    <a class="skip" href="#main">Skip to content</a>
    <header class="site-header" data-header>
      <div class="shell nav-wrap">
        <a class="brand" href="/" aria-label="Mault home"><img class="brand-logo" src="/assets/mault-logo.png" alt="Mault" width="903" height="313" /></a>
        <nav class="desktop-nav" aria-label="Primary">
          {nav.map(([href, label]) => <a href={href}>{label}</a>)}
        </nav>
        <a class="button button-small desktop-cta" href="/pilot/">Start a pilot</a>
        <button class="menu-button" type="button" aria-expanded="false" aria-controls="mobile-menu"><span></span><span></span><span></span><span class="sr-only">Menu</span></button>
      </div>
      <nav id="mobile-menu" class="mobile-nav" aria-label="Mobile" hidden>
        {nav.map(([href, label]) => <a href={href}>{label}</a>)}
        <a class="button" href="/pilot/">Start a pilot</a>
      </nav>
    </header>
    <main id="main"><slot /></main>
    <footer class="site-footer">
      <div class="shell footer-grid">
        <div><a class="brand" href="/" aria-label="Mault home"><img class="brand-logo" src="/assets/mault-logo.png" alt="Mault" width="903" height="313" /></a><p>Deterministic governance for AI-written code.</p></div>
        <div><h2>Explore</h2><a href="/platform/">Platform</a><a href="/how-it-works/">How it works</a><a href="/pricing/">Pricing</a><a href="/docs/">Docs</a></div>
        <div><h2>Company</h2><a href="/blog/">Blog</a><a href="/contact/">Contact</a><a href="/pilot/">Pilot</a><a href="mailto:contact@mault.ai">contact@mault.ai</a></div>
        <div><h2>Legal</h2><a href="/privacy/">Privacy</a><a href="/terms/">Terms</a><a href="/billing/">Billing</a><a href="/cookie-policy/">Cookies</a></div>
      </div>
      <div class="shell footer-bottom"><span>© {new Date().getFullYear()} Mault</span><span>Govern code. Prove control.</span></div>
    </footer>
    <script>
      const button = document.querySelector('.menu-button');
      const menu = document.querySelector('#mobile-menu');
      button?.addEventListener('click', () => {
        const open = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!open));
        if (menu instanceof HTMLElement) menu.hidden = open;
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && button?.getAttribute('aria-expanded') === 'true') {
          button.setAttribute('aria-expanded', 'false'); if (menu instanceof HTMLElement) menu.hidden = true;
        }
      });
      const observer = new IntersectionObserver((entries) => entries.forEach((entry) => {
        if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); }
      }), { threshold: .12 });
      document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const splash = document.querySelector('[data-splash]');
      const splashCount = document.querySelector('[data-splash-count]');
      const splashBar = document.querySelector('[data-splash-bar]');
      const hasSeenSplash = sessionStorage.getItem('mault-splash-seen') === '1';
      const closeSplash = () => {
        splash?.classList.add('is-complete');
        document.body.classList.remove('splash-active');
        sessionStorage.setItem('mault-splash-seen', '1');
        window.setTimeout(() => splash?.remove(), 500);
      };
      if (splash && !hasSeenSplash && !reducedMotion) {
        document.body.classList.add('splash-active');
        const started = performance.now();
        const duration = 1050;
        const tick = (now: number) => {
          const progress = Math.min(100, Math.round(((now - started) / duration) * 100));
          if (splashCount) splashCount.textContent = `${progress}%`;
          if (splashBar instanceof HTMLElement) splashBar.style.width = `${progress}%`;
          if (progress < 100) requestAnimationFrame(tick); else window.setTimeout(closeSplash, 180);
        };
        requestAnimationFrame(tick);
      } else splash?.remove();

      const counterObserver = new IntersectionObserver((entries) => entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const element = entry.target;
        const end = Number(element.getAttribute('data-count') || 0);
        const suffix = element.getAttribute('data-suffix') || '';
        const decimals = Number(element.getAttribute('data-decimals') || 0);
        if (reducedMotion) { element.textContent = `${end.toFixed(decimals)}${suffix}`; counterObserver.unobserve(element); return; }
        const start = performance.now();
        const animate = (now: number) => {
          const ratio = Math.min(1, (now - start) / 900);
          const eased = 1 - Math.pow(1 - ratio, 3);
          element.textContent = `${(end * eased).toFixed(decimals)}${suffix}`;
          if (ratio < 1) requestAnimationFrame(animate);
        };
        requestAnimationFrame(animate);
        counterObserver.unobserve(element);
      }), { threshold: .65 });
      document.querySelectorAll('[data-count]').forEach((el) => counterObserver.observe(el));

      const terminal = document.querySelector('[data-terminal-sequence]');
      const playTerminal = (force = false) => {
        if (!(terminal instanceof HTMLElement) || (!force && terminal.dataset.played === 'true')) return;
        terminal.dataset.played = 'true';
        const command = terminal.querySelector('[data-command]');
        const steps = [...terminal.querySelectorAll('[data-terminal-step]')];
        if (!(command instanceof HTMLElement) || reducedMotion) {
          terminal.classList.add('is-complete');
          return;
        }
        const text = command.dataset.command || '';
        command.textContent = '';
        steps.forEach((step) => step.classList.remove('is-visible'));
        terminal.classList.remove('is-complete');
        terminal.classList.add('is-running');
        let index = 0;
        const typeNext = () => {
          command.textContent = text.slice(0, index += 1);
          if (index < text.length) window.setTimeout(typeNext, index < 6 ? 75 : 38);
          else steps.forEach((step, stepIndex) => window.setTimeout(() => {
            step.classList.add('is-visible');
            if (stepIndex === steps.length - 1) terminal.classList.add('is-complete');
          }, 260 + stepIndex * 360));
        };
        window.setTimeout(typeNext, 220);
      };
      if (terminal) {
        const terminalObserver = new IntersectionObserver((entries) => entries.forEach((entry) => {
          if (entry.isIntersecting) { playTerminal(); terminalObserver.disconnect(); }
        }), { threshold: .45 });
        terminalObserver.observe(terminal);
      }

      document.querySelector('[data-terminal-replay]')?.addEventListener('click', () => playTerminal(true));

      const agentSection = document.querySelector('[data-agent-section]');
      if (agentSection) {
        const agentObserver = new IntersectionObserver((entries) => entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          agentObserver.disconnect();
        }), { threshold: .2 });
        agentObserver.observe(agentSection);
      }

      const flowFeatures = document.querySelectorAll('[data-flow-feature]');
      const flowObserver = new IntersectionObserver((entries) => entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-flow-visible');
        flowObserver.unobserve(entry.target);
      }), { threshold: .35 });
      flowFeatures.forEach((feature) => flowObserver.observe(feature));
      document.querySelectorAll('[data-flow-row]').forEach((row) => row.addEventListener('click', () => {
        const flow = row.closest('[data-flow]');
        flow?.querySelectorAll('[data-flow-row]').forEach((item) => {
          item.classList.remove('is-selected');
          item.setAttribute('aria-pressed', 'false');
        });
        row.classList.add('is-selected');
        row.setAttribute('aria-pressed', 'true');
        const inspector = flow?.querySelector('[data-flow-inspector]');
        const label = row.querySelector('span')?.textContent?.trim() || 'Selected step';
        const detail = row.getAttribute('data-detail') || 'Execution detail is available for this workflow step.';
        if (inspector instanceof HTMLElement) {
          const status = inspector.querySelector('span');
          const copy = inspector.querySelector('p');
          if (status) status.textContent = `${label} · verified`;
          if (copy) copy.textContent = detail;
          inspector.classList.remove('is-active');
          requestAnimationFrame(() => inspector.classList.add('is-active'));
        }
      }));
    </script>
  </body>
</html>
