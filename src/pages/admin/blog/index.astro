---
import SiteLayout from '../../../layouts/SiteLayout.astro';
---
<SiteLayout title="Blog Studio | Mault Demo" description="Create and manage Mault blog posts." canonical="/admin/blog/">
  <section class="studio-login shell" data-studio-login aria-labelledby="studio-login-title">
    <div class="studio-login-card">
      <div><p class="eyebrow">Protected demo workspace</p><h1 id="studio-login-title">Mault Blog Studio</h1><p>This public prototype uses shared demo credentials. It is an interface gate, not production authentication.</p></div>
      <form data-studio-login-form>
        <label class="field"><span>Email</span><input name="email" type="email" autocomplete="username" required value="demo@mault.ai" /></label>
        <label class="field"><span>Demo passphrase</span><input name="passphrase" type="password" autocomplete="current-password" required /></label>
        <p class="login-error" data-login-error role="alert" hidden>That demo passphrase does not match.</p>
        <button class="button" type="submit">Open Blog Studio</button>
      </form>
      <div class="demo-credentials"><span>Public demo access</span><code>demo@mault.ai</code><code>govern-the-code</code></div>
      <div class="future-login" aria-label="Future sign-in options"><button type="button" disabled>Sign in with Google <small>Coming soon</small></button><button type="button" disabled>Sign in with Microsoft 365 <small>Coming soon</small></button></div>
      <p class="login-note">A production deployment would replace this shared gate with role-based Google Workspace and Microsoft 365 OAuth, server-side sessions, and an authenticated publishing API.</p>
    </div>
  </section>
  <main class="studio shell" data-blog-studio hidden>
    <header class="studio-head"><div><p class="eyebrow">Mault content studio</p><h1>Blog posts</h1><p>Create, preview, and manage posts without touching the site code.</p></div><button class="button" type="button" data-new-post>+ New post</button></header>
    <div class="studio-layout">
      <aside class="post-library" aria-label="Saved posts"><div class="library-head"><strong>Posts</strong><span data-post-count>0 posts</span></div><div class="post-list" data-post-list><p class="empty-state">No posts yet. Create the first one.</p></div></aside>
      <section class="editor-panel"><form data-post-form>
        <input type="hidden" name="id" />
        <div class="editor-toolbar"><div><span class="status-dot"></span><span data-save-state>New draft</span></div><div class="toolbar-actions"><button class="button button-secondary button-small" type="button" data-preview>Preview</button><button class="button button-small" type="submit">Save post</button></div></div>
        <div class="field-grid">
          <label class="field field-wide"><span>Post title</span><input name="title" required placeholder="Enter a clear, useful title" /></label>
          <label class="field"><span>URL slug</span><div class="slug-field"><b>/blog/</b><input name="slug" required placeholder="post-url" /></div></label>
          <label class="field"><span>Publish date</span><input name="date" type="date" required /></label>
          <label class="field"><span>Author</span><input name="author" placeholder="Mault Team" /></label>
          <label class="field"><span>Status</span><select name="status"><option value="draft">Draft</option><option value="published">Published</option><option value="scheduled">Scheduled</option></select></label>
          <label class="field field-wide"><span>Short excerpt</span><textarea name="excerpt" rows="3" placeholder="A short summary shown on the blog page and in search results."></textarea></label>
          <label class="field field-wide"><span>Cover image</span><div class="image-picker"><input name="image" type="file" accept="image/png,image/jpeg,image/webp,image/gif" /><span>PNG, JPG, WebP, or GIF</span></div><input name="imageData" type="hidden" /><div class="image-preview" data-image-preview hidden></div></label>
          <label class="field field-wide"><span>Post content (HTML)</span><textarea class="code-editor" name="content" rows="18" required spellcheck="false" placeholder="&lt;h2&gt;Start with a strong heading&lt;/h2&gt;&#10;&lt;p&gt;Write the article here...&lt;/p&gt;"></textarea><small>Use standard HTML for headings, paragraphs, links, lists, quotes, and images.</small></label>
          <details class="seo-fields field-wide"><summary>SEO settings</summary><div class="field-grid"><label class="field"><span>SEO title</span><input name="seoTitle" /></label><label class="field"><span>SEO description</span><textarea name="seoDescription" rows="3"></textarea></label></div></details>
        </div>
        <div class="editor-footer"><button class="danger-link" type="button" data-delete hidden>Delete post</button><p>This demo stores drafts in this browser. Publishing integration is connected in the next backend step.</p></div>
      </form></section>
    </div>
  </main>
  <dialog class="post-preview" data-preview-dialog><button class="preview-close" type="button" data-close-preview aria-label="Close preview">×</button><article><p class="eyebrow">Mault journal</p><h1 data-preview-title>Untitled post</h1><div class="preview-meta" data-preview-meta></div><div class="preview-cover" data-preview-cover hidden></div><div class="preview-body prose" data-preview-body></div></article></dialog>
  <script>
    // @ts-nocheck -- DOM elements are guaranteed by this self-contained page.
    const root = document.querySelector('[data-blog-studio]');
    const login = document.querySelector('[data-studio-login]');
    const loginForm = document.querySelector('[data-studio-login-form]');
    const loginError = document.querySelector('[data-login-error]');
    const unlockStudio = () => { if (root) root.hidden = false; if (login) login.hidden = true; };
    if (sessionStorage.getItem('mault-demo-studio-access') === 'granted') unlockStudio();
    loginForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      const data = new FormData(loginForm);
      const valid = data.get('email') === 'demo@mault.ai' && data.get('passphrase') === 'govern-the-code';
      if (!valid) { if (loginError) loginError.hidden = false; return; }
      sessionStorage.setItem('mault-demo-studio-access', 'granted');
      unlockStudio();
    });
    if (root) {
      const key = 'mault-demo-blog-posts-v1'; const form = root.querySelector('[data-post-form]'); const list = root.querySelector('[data-post-list]'); const count = root.querySelector('[data-post-count]'); const saveState = root.querySelector('[data-save-state]'); const deleteButton = root.querySelector('[data-delete]'); const imagePreview = root.querySelector('[data-image-preview]'); const dialog = document.querySelector('[data-preview-dialog]'); let posts = JSON.parse(localStorage.getItem(key) || '[]');
      const escapeHtml = (value = '') => value.replace(/[&<>"]/g, (char) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[char])); const slugify = (value = '') => value.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''); const fields = () => { const data = Object.fromEntries(new FormData(form).entries()); delete data.image; return data; }; const persist = () => localStorage.setItem(key, JSON.stringify(posts));
      const safeArticleHtml = (html = '') => { const doc = new DOMParser().parseFromString(`<main>${html}</main>`, 'text/html'); const safeUrl = (value, attribute) => { const url = value.trim(); if (/^(https?:|\/|#)/i.test(url)) return true; if (attribute === 'href' && /^mailto:/i.test(url)) return true; return attribute === 'src' && /^data:image\/(png|jpeg|webp|gif);base64,/i.test(url); }; doc.querySelectorAll('script,style,iframe,object,embed,form,input,button,link,meta').forEach((node) => node.remove()); doc.querySelectorAll('*').forEach((node) => { [...node.attributes].forEach((attribute) => { const name = attribute.name.toLowerCase(); if (name.startsWith('on') || name === 'style' || ((name === 'href' || name === 'src') && !safeUrl(attribute.value, name))) node.removeAttribute(attribute.name); }); if (node.getAttribute('target') === '_blank') node.setAttribute('rel', 'noopener noreferrer'); }); return doc.querySelector('main')?.innerHTML || ''; };
      function renderList() { count.textContent = `${posts.length} post${posts.length === 1 ? '' : 's'}`; if (!posts.length) { list.innerHTML = '<p class="empty-state">No posts yet. Create the first one.</p>'; return; } list.innerHTML = posts.slice().sort((a,b) => b.updated.localeCompare(a.updated)).map((post) => `<button type="button" class="post-row" data-edit-id="${post.id}"><span class="post-status ${post.status}">${post.status}</span><strong>${escapeHtml(post.title || 'Untitled post')}</strong><small>${escapeHtml(post.date || 'No date')}</small></button>`).join(''); }
      function resetForm() { form.reset(); form.elements.id.value = ''; form.elements.author.value = 'Mault Team'; form.elements.date.value = new Date().toISOString().slice(0,10); form.elements.imageData.value = ''; imagePreview.hidden = true; imagePreview.innerHTML = ''; deleteButton.hidden = true; saveState.textContent = 'New draft'; form.elements.title.focus(); }
      function editPost(id) { const post = posts.find((item) => item.id === id); if (!post) return; Object.entries(post).forEach(([name,value]) => { if (form.elements[name] && name !== 'image') form.elements[name].value = value || ''; }); if (post.imageData) { imagePreview.innerHTML = `<img src="${post.imageData}" alt="" />`; imagePreview.hidden = false; } else { imagePreview.hidden = true; imagePreview.innerHTML = ''; } deleteButton.hidden = false; saveState.textContent = `Editing ${post.status}`; window.scrollTo({top:0,behavior:'smooth'}); }
      form.elements.title.addEventListener('input', () => { if (!form.elements.slug.dataset.touched) form.elements.slug.value = slugify(form.elements.title.value); }); form.elements.slug.addEventListener('input', () => { form.elements.slug.dataset.touched = 'true'; form.elements.slug.value = slugify(form.elements.slug.value); });
      form.elements.image.addEventListener('change', () => { const file = form.elements.image.files[0]; if (!file) return; if (file.size > 2000000) { alert('Please use an image under 2MB for this demo.'); form.elements.image.value = ''; return; } const reader = new FileReader(); reader.onload = () => { form.elements.imageData.value = reader.result; imagePreview.innerHTML = `<img src="${reader.result}" alt="" />`; imagePreview.hidden = false; }; reader.readAsDataURL(file); });
      form.addEventListener('submit', (event) => { event.preventDefault(); const post = fields(); post.id ||= crypto.randomUUID(); post.updated = new Date().toISOString(); const index = posts.findIndex((item) => item.id === post.id); if (index >= 0) posts[index] = post; else posts.push(post); persist(); renderList(); editPost(post.id); saveState.textContent = `Saved ${new Date().toLocaleTimeString([], {hour:'numeric',minute:'2-digit'})}`; });
      list.addEventListener('click', (event) => { const row = event.target.closest('[data-edit-id]'); if (row) editPost(row.dataset.editId); }); root.querySelector('[data-new-post]').addEventListener('click', resetForm); deleteButton.addEventListener('click', () => { const id = form.elements.id.value; if (id && confirm('Delete this draft?')) { posts = posts.filter((item) => item.id !== id); persist(); renderList(); resetForm(); } });
      root.querySelector('[data-preview]').addEventListener('click', () => { const post = fields(); dialog.querySelector('[data-preview-title]').textContent = post.title || 'Untitled post'; dialog.querySelector('[data-preview-meta]').textContent = `${post.author || 'Mault Team'} · ${post.date || 'Draft'}`; const cover = dialog.querySelector('[data-preview-cover]'); cover.innerHTML = post.imageData ? `<img src="${post.imageData}" alt="" />` : ''; cover.hidden = !post.imageData; dialog.querySelector('[data-preview-body]').innerHTML = safeArticleHtml(post.content || '<p>Start writing to preview the article.</p>'); dialog.showModal(); }); document.querySelector('[data-close-preview]').addEventListener('click', () => dialog.close()); renderList(); resetForm();
    }
  </script>
</SiteLayout>
