---
import SiteLayout from '../layouts/SiteLayout.astro'; import '../styles/marketing-pages.css'; const items=['Custom governance rule design','Organization-wide enforcement','Tailored onboarding and workflow alignment','Dedicated support','CI/CD integration guidance','Policy customization across teams'];
---
<SiteLayout title="Mault Enterprise | Organization-Wide AI Governance" description="Custom policies, organization-wide enforcement, CI/CD alignment, and evidence for enterprise AI coding workflows." canonical="/enterprise/"><header class="mp-hero"><div class="shell mp-hero-grid"><div><p class="eyebrow">Enterprise</p><h1>Deterministic governance across <span class="gradient-text">your organization.</span></h1><p class="lede">Standardize how engineering teams deploy coding agents while preserving the controls, evidence, and workflows your organization requires.</p><div class="hero-actions"><a class="button" href="/contact/">Talk to Mault</a><a class="button button-secondary" href="/pilot/">Start with a pilot</a></div></div><aside class="mp-panel"><p class="eyebrow">Everything in Pro, plus</p><ul class="mp-list">{items.map(x=><li>{x}</li>)}</ul></aside></div></header><section class="section mp-band"><div class="shell"><div class="section-head"><div><p class="eyebrow">Enterprise control plane</p><h2>One standard. Many teams.</h2></div><p>Central governance gives platform and security leaders control while development teams keep moving inside their existing tools.</p></div><div class="mp-grid-3"><article class="mp-card"><span>Policy</span><h3>Rules matched to your environment</h3><p>Encode protected paths, review thresholds, testing requirements, architecture rules, and approval boundaries.</p></article><article class="mp-card"><span>Operations</span><h3>Roll out without runtime replacement</h3><p>Align Mault with repositories, coding agents, CI/CD controls, and team ownership already in place.</p></article><article class="mp-card"><span>Evidence</span><h3>Auditability across teams</h3><p>Standardize attribution and evidence while retaining the detail needed for each decision.</p></article></div></div></section><section class="section"><div class="shell"><p class="eyebrow">Deployment path</p><h2 class="mp-section-title">From one workflow to organization-wide control.</h2><div class="mp-steps"><article class="mp-step"><h3>Scope the highest-value workflow</h3><p>Choose the agent, repository, policy boundary, and measurable outcome.</p></article><article class="mp-step"><h3>Deploy and validate</h3><p>Run real work through deterministic decisions and review the resulting evidence.</p></article><article class="mp-step"><h3>Standardize the control model</h3><p>Convert pilot findings into repeatable policies and rollout guidance.</p></article></div></div></section><section class="cta"><div class="shell cta-box"><h2>Bring governed AI development to every team.</h2><a class="button" href="/contact/">Start the conversation</a></div></section></SiteLayout>
