---
import SiteLayout from '../layouts/SiteLayout.astro'; import '../styles/marketing-pages.css';
const groups: [string, [string, string][]][] = [
['Getting started',[['What is Mault?','Mault is a deterministic governance layer for AI-written code. It connects developer identity, agent intent, policy decisions, enforcement, and evidence.'],['Does Mault replace my coding agent?','No. Mault governs the coding tools and workflows your team already uses.'],['Where should a team start?','Start with one high-value workflow where agent rework, protected paths, or missing evidence creates measurable risk.']]],
['Compatibility',[['Which tools are supported?','The demo includes Claude Code, Cursor, GitHub Copilot, Windsurf, OpenAI Codex, Augment, Cline, Kiro, and Gemini.'],['Does Mault work with CI/CD?','Enterprise deployments align policy and evidence with existing repositories and CI/CD controls.']]],
['Security and privacy',[['Does Mault train on our code?','The public demo makes no claim that customer code is used for model training. Production data-handling terms should be confirmed during deployment.'],['What evidence is captured?','Authenticated identity, agent intent, affected scope, evaluated policy, outcome, and execution evidence.']]],
['Pricing',[['What is Core?','Core provides continuous analysis, drift detection, and guided remediation.'],['What does Pro add?','Pro adds automatic enforcement, commit blocking, production-readiness controls, and earlier access to new governance capabilities.']]],
];
---
<SiteLayout title="Mault FAQ | AI Coding Governance Questions" description="Straight answers about Mault installation, compatibility, enforcement, security, evidence, and pricing." canonical="/faq/"><header class="mp-hero"><div class="shell"><p class="eyebrow">FAQ</p><h1 class="display">Common questions.<br/><span class="gradient-text">Straight answers.</span></h1><p class="lede">Everything you need to understand the governance model before starting a pilot.</p></div></header><section class="section"><div class="shell mp-faq">{groups.map(([group,questions])=><section><p class="eyebrow">{group}</p>{questions.map(([q,a])=><details><summary>{q}</summary><p>{a}</p></details>)}</section>)}</div></section><section class="cta"><div class="shell cta-box"><h2>Still evaluating your control gap?</h2><p>Ask Mault Bot or start a technical conversation.</p><div class="hero-actions" style="justify-content:center"><a class="button" href="/contact/">Contact Mault</a><a class="button button-secondary" href="/pilot/">Explore the pilot</a></div></div></section></SiteLayout>
