---
import SiteLayout from '../layouts/SiteLayout.astro';
const agents = [
  ['VS Code','vscode','https://code.visualstudio.com/'],
  ['Cursor','cursor','https://www.cursor.com/'],
  ['Claude Code','claude-code','https://www.anthropic.com/claude-code'],
  ['Codex','codex','https://openai.com/codex/'],
  ['GitHub Copilot','copilot','https://github.com/features/copilot'],
  ['Gemini Code Assist','gemini','https://codeassist.google/'],
  ['Cline','cline','https://cline.bot/'],
  ['Windsurf','windsurf','https://windsurf.com/'],
  ['Kiro','kiro','https://kiro.dev/'],
];
const pillars = [
  ['Enforce','Rules execute before agent actions, not after damage is done.'],
  ['See','Every state-changing action becomes observable across your team.'],
  ['Prove','Tamper-evident evidence gives security and compliance teams the record they need.'],
];
const features = [
  ['Rules your agents can’t bypass','Policy becomes an execution boundary. Mault evaluates actions before they change files, run commands, or cross protected paths.','policy loaded','write evaluated','rule enforced'],
  ['See every action that changes state','Trace the complete chain from identity and intent to tool execution and resulting change.','session attributed','action recorded','change linked'],
  ['The proof your teams are asking for','Produce a durable record for audits, incident review, and production governance without shipping source code to a third party.','evidence sealed','chain verified','report ready'],
  ['Run governance from one place','Distribute standards across contributors and coding agents while keeping exceptions explicit and reviewable.','policy synced','team aligned','exceptions visible'],
  ['Parallel agents without file collisions','Coordinate concurrent work with deterministic ownership and protected boundaries instead of hoping agents stay out of each other’s way.','scope reserved','conflict prevented','work merged'],
];
const flowDetails: Record<string,string> = {
  'policy loaded':'The repository policy is resolved locally and its signed version is attached to this run.',
  'write evaluated':'The proposed file mutation is checked against protected paths, architecture rules, and allowed scope.',
  'rule enforced':'The action is permitted or blocked before an invalid change can reach disk.',
  'session attributed':'The developer, agent, repository, branch, and machine identity are linked to one session.',
  'action recorded':'Every state-changing tool call is recorded with intent, inputs, affected scope, and result.',
  'change linked':'The resulting diff is connected to the action and identity that produced it.',
  'evidence sealed':'The decision record is hashed and sealed so later modification becomes detectable.',
  'chain verified':'Each evidence record verifies against the previous record in the local audit chain.',
  'report ready':'The verified chain can be exported for security, compliance, or incident review.',
  'policy synced':'Approved organization policy is distributed consistently to contributors and agents.',
  'team aligned':'Every supported coding surface evaluates the same deterministic standards.',
  'exceptions visible':'Overrides remain explicit, attributed, time-bound, and reviewable.',
  'scope reserved':'The agent receives deterministic ownership of the files and tasks assigned to it.',
  'conflict prevented':'Overlapping writes are identified before parallel agents collide.',
  'work merged':'Verified outputs return through a controlled integration path with evidence intact.',
};
const faqs = [
  ['Does Mault replace my coding agent?','No. Mault is the governance and orchestration layer around the agents your team already uses.'],
  ['Does our code leave our environment?','The platform is designed to run locally and in air-gapped environments so source code and evidence remain under your control.'],
  ['Which agents are supported?','The current product story includes Claude Code, Cursor, Codex, Copilot, Gemini, Cline, Windsurf, Augment, and Kiro.'],
  ['Is this only for regulated companies?','No. Regulated teams value the evidence, but any engineering organization can use deterministic rules and visibility to control AI-written code.'],
];
---
<SiteLayout title="Mault | Govern the code your AI writes" description="Deterministic governance, observability, and evidence for AI-assisted software development.">
  <section class="hero">
    <div class="shell">
      <p class="eyebrow">Deterministic governance, from keystroke to merge</p>
      <h1 class="display">Govern the code your AI <span class="gradient-text">writes.</span></h1>
      <p class="lede">Observe and enforce at scale. Mault turns your engineering rules into execution boundaries and produces the evidence to prove every agent stayed inside them.</p>
      <div class="hero-actions"><a class="button" href="/pilot/">Start a pilot</a><a class="button button-secondary" href="/how-it-works/">See how it works</a></div>
      <div class="hero-proof" data-reveal>
        <div class="terminal" aria-label="Example Mault governance output">
          <div class="terminal-bar"><span class="terminal-dots" aria-hidden="true"><i></i><i></i><i></i></span><button class="terminal-replay" type="button" data-terminal-replay aria-label="Replay terminal animation">Replay</button></div>
          <div class="terminal-sequence" data-terminal-sequence>
            <div class="command"><span class="terminal-prompt" aria-hidden="true">$</span> <span class="terminal-command" data-command="mault run --policy production">mault run --policy production</span><span class="terminal-caret" aria-hidden="true"></span></div>
            <div class="terminal-line" data-terminal-step><span>01</span><span>Identity linked to authenticated developer</span></div>
            <div class="terminal-line" data-terminal-step><span>02</span><span>Agent intent and affected scope captured</span></div>
            <div class="terminal-line" data-terminal-step><span>03</span><span>Protected-path policy evaluated</span></div>
            <div class="terminal-line" data-terminal-step><span>04</span><span style="color:var(--green)">Action permitted · evidence sealed</span></div>
          </div>
        </div>
        <div class="proof-side"><span class="status">Governance active</span><div class="metric"><strong data-count="100" data-suffix="%">100%</strong><span>State-changing actions attributed</span></div><div class="metric"><strong data-count="0">0</strong><span>Unreviewed policy bypasses</span></div></div>
      </div>
    </div>
  </section>
  <section class="agent-strip" aria-labelledby="agent-heading" data-agent-section><div class="shell"><div class="agent-intro"><div><p class="eyebrow">Works with your stack</p><h2 id="agent-heading">One governance layer.<br/>Every coding surface.</h2></div><p>Explore the tools Mault is designed to govern. Each interactive tile opens the official product site.</p></div><div class="agent-list">{agents.map(([name,slug,url], index)=><a class="agent-tile" data-agent-tile style={`--tile-delay:${index * 70}ms`} href={url} target="_blank" rel="noopener noreferrer" aria-label={`${name} official website (opens in a new tab)`}><span class="agent-icon"><img src={`/assets/agents/${slug}.svg`} alt="" width="32" height="32" loading="lazy" /></span><strong>{name}</strong><span class="agent-arrow" aria-hidden="true">↗</span></a>)}</div></div></section>
  <section class="section" id="problem"><div class="shell">
    <div class="section-head" data-reveal><div><p class="eyebrow">The gap</p><h2>AI writes code.<br/>Mault enforces your rules.</h2></div><p>Prompts and rules files express intent. They do not prove compliance. Mault makes governance deterministic at the moment an agent attempts to change state.</p></div>
    <div class="cards-3">{pillars.map(([title,body],i)=><article class="card" data-reveal><span class="card-index">0{i+1}</span><h3>{title}</h3><p>{body}</p></article>)}</div>
  </div></section>
  <section class="section"><div class="shell">{features.map(([title,body,...steps],i)=><article class="feature" data-reveal data-flow-feature><div><p class="eyebrow">{String(i+1).padStart(2,'0')} / Platform</p><h3>{title}</h3><p>{body}</p><a class="button button-secondary" href="/platform/">Explore the platform</a></div><div class="visual"><div class="flow" data-flow>{steps.map((step,stepIndex)=><button class="flow-row" type="button" data-flow-row data-detail={flowDetails[step]} aria-pressed="false" style={`--flow-delay:${stepIndex * 180}ms`}><span>{step}</span><small>Inspect</small></button>)}<div class="flow-inspector" data-flow-inspector aria-live="polite"><span>Ready</span><p>Select a workflow step to inspect its enforcement record.</p></div></div></div></article>)}</div></section>
  <section class="proof-stats"><div class="shell"><div class="proof-stats-head"><p class="eyebrow">Measured outcomes</p><h2>Governance you can quantify.</h2></div><div class="proof-stat-grid"><article><strong data-count="0.18" data-decimals="2" data-suffix="%">0.18%</strong><span>Revert rate on governed code</span></article><article><strong data-count="2.6" data-decimals="1" data-suffix="%">2.6%</strong><span>Code duplication rate</span></article><article><strong data-count="100" data-suffix="%">100%</strong><span>State-changing actions attributed</span></article></div><p class="proof-note">Performance figures carried forward from the current Mault product story. Final production copy should link each metric to its supporting methodology.</p></div></section>
  <section class="quote-band"><div class="shell"><p>Better prompts. Better specs. Better rules files. <strong>It’s not enough.</strong></p></div></section>
  <section class="section" id="pricing"><div class="shell"><div class="section-head"><div><p class="eyebrow">Pricing</p><h2>Governance for teams of all sizes.</h2></div><p>Start with individual control, then standardize policy and evidence across the organization.</p></div><div class="pricing"><article class="price-card"><p class="eyebrow">Pro</p><h3>For builders and small teams</h3><div class="price">$19–$49 <small>/ month</small></div><ul><li>Local governance controls</li><li>Agent activity records</li><li>Production-readiness checks</li></ul><a class="button button-secondary" href="/contact/">Talk to us</a></article><article class="price-card featured"><p class="eyebrow">Enterprise</p><h3>For governed organizations</h3><div class="price">Custom</div><ul><li>Central policy management</li><li>Organization-wide evidence</li><li>Air-gapped deployment options</li></ul><a class="button" href="/pilot/">Start a pilot</a></article></div></div></section>
  <section class="section" id="faq"><div class="shell"><div class="section-head"><div><p class="eyebrow">FAQ</p><h2>Questions teams ask before they buy.</h2></div><p>Clear answers about architecture, deployment, supported agents, and control.</p></div><div class="faq-list">{faqs.map(([q,a])=><details><summary>{q}</summary><p>{a}</p></details>)}</div></div></section>
  <section class="cta"><div class="shell"><div class="cta-box"><p class="eyebrow">Ready when you are</p><h2>Govern the code your AI writes.</h2><p>Bring deterministic rules and audit-ready evidence to your engineering workflow.</p><a class="button" href="/pilot/">Start a pilot</a></div></div></section>
</SiteLayout>
