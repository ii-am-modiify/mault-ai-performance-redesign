---
import SiteLayout from '../layouts/SiteLayout.astro';
const timeline = [
  ['01','Scope','Map your agents, repositories, protected paths, and current review bottlenecks.'],
  ['02','Deploy','Install Mault locally or air-gapped and translate standards into deterministic policy.'],
  ['03','Measure','Run governed workflows and measure reverts, review debt, violations, and attribution.'],
  ['04','Prove','Review the evidence chain and receive a production rollout recommendation.'],
];
const agents = ['Claude Code','Cursor','GitHub Copilot','Windsurf','OpenAI Codex','Augment','Cline','Kiro','Gemini'];
---
<SiteLayout title="45-Day Enterprise Pilot | Mault" description="Run Mault against your real AI coding workflow for 45 days with up to five developers, local deployment, and measurable governance outcomes." canonical="/pilot/">
  <main class="pilot-page">
    <section class="pilot-hero"><div class="shell pilot-hero-grid">
      <div><p class="eyebrow">Mault · 45-day pilot</p><h1>Prove AI governance<br/><span class="gradient-text">inside your stack.</span></h1><p class="lede">A focused engagement for engineering and security teams that need to scale coding agents without losing control, visibility, or evidence.</p><div class="hero-actions"><a class="button" href="#apply">Request a pilot</a><a class="button button-secondary" href="#plan">See the plan</a></div></div>
      <aside class="pilot-summary" aria-label="Pilot summary"><span class="status">Pilot environment ready</span><div><strong>45</strong><small>days</small></div><ul><li>Up to 5 developers</li><li>Local or air-gapped</li><li>Weekly implementation reviews</li><li>Fee credited toward rollout</li></ul></aside>
    </div></section>
    <section class="pilot-proof"><div class="shell pilot-proof-grid"><div><strong>$999</strong><span>Fixed pilot fee</span></div><div><strong>0</strong><span>Source-code uploads</span></div><div><strong>5</strong><span>Developers included</span></div><div><strong>1</strong><span>Rollout recommendation</span></div></div></section>
    <section class="section" id="plan"><div class="shell"><div class="section-head"><div><p class="eyebrow">The engagement</p><h2>From first policy to verified evidence.</h2></div><p>The pilot is deliberately narrow: one real workflow, measurable outcomes, and a production decision backed by evidence rather than a slide deck.</p></div><div class="pilot-timeline">{timeline.map(([number,title,copy])=><article data-reveal><span>{number}</span><div><h3>{title}</h3><p>{copy}</p></div></article>)}</div></div></section>
    <section class="section pilot-fit"><div class="shell pilot-fit-grid"><div><p class="eyebrow">Who it is for</p><h2>Teams already feeling the AI rework tax.</h2><p>Best suited to CTO, VP Engineering, platform, security, and compliance leaders adopting coding agents across production repositories.</p></div><div class="pilot-checks"><p>✓ Agents are opening more pull requests than reviewers can safely absorb.</p><p>✓ Rules files and prompts cannot prove that standards were followed.</p><p>✓ Security needs attribution for every state-changing action.</p><p>✓ Source code must remain local or inside an air-gapped environment.</p></div></div></section>
    <section class="section"><div class="shell"><div class="section-head"><div><p class="eyebrow">Supported surfaces</p><h2>Start with the tools your team already uses.</h2></div><p>The pilot is scoped to your highest-value agent workflow. No new coding runtime is required.</p></div><div class="pilot-agents">{agents.map(agent=><span>{agent}</span>)}</div></div></section>
    <section class="pilot-apply" id="apply"><div class="shell pilot-apply-grid"><div><p class="eyebrow">Request a pilot</p><h2>Tell us where governance needs to hold.</h2><p>This independent demo records submissions locally and does not contact Mault or send production email.</p><div class="pilot-contact-note"><strong>What happens next</strong><span>Architecture review · scope confirmation · installation plan</span></div></div>
      <form class="pilot-form" data-pilot-form><div class="form-row"><label>First name<input name="firstName" autocomplete="given-name" required /></label><label>Last name<input name="lastName" autocomplete="family-name" required /></label></div><label>Work email<input name="email" type="email" autocomplete="email" required /></label><label>Company<input name="company" autocomplete="organization" required /></label><label>Team size<select name="teamSize" required><option value="">Select team size</option><option>2–10</option><option>11–50</option><option>51–200</option><option>200+</option></select></label><label>Primary coding agent<select name="agent" required><option value="">Select an agent</option>{agents.map(agent=><option>{agent}</option>)}<option>Not using agents yet</option></select></label><label>What needs governance?<textarea name="goal" rows="4" placeholder="Protected paths, review bottlenecks, compliance requirements…" required></textarea></label><button class="button" type="submit">Request demo pilot</button><p class="form-status" data-pilot-status aria-live="polite"></p></form>
    </div></section>
  </main>
  <script>
    const form = document.querySelector('[data-pilot-form]');
    form?.addEventListener('submit', (event) => { event.preventDefault(); const status = document.querySelector('[data-pilot-status]'); if (status) status.textContent = 'Demo request captured in this browser. No email was sent.'; form.classList.add('is-submitted'); });
  </script>
</SiteLayout>
