---
import SiteLayout from '../layouts/SiteLayout.astro'; import '../styles/marketing-pages.css';
const capabilities=[['Identity binding','Connect every agent action to an authenticated developer and session.'],['Intent capture','Record requested change, affected scope, and expected outcome before execution.'],['Policy enforcement','Turn engineering standards into deterministic permit or block decisions.'],['Evidence sealing','Preserve decision context and outcome for review, audit, and compliance.'],['Agent isolation','Keep specialized agents inside approved responsibilities and boundaries.'],['Stack integration','Govern the coding tools engineers already use without replacing their runtime.']];
---
<SiteLayout title="Mault Platform | Deterministic AI Code Governance" description="The control plane for AI-written code: identity, intent, policy enforcement, and evidence across every agent action." canonical="/platform/"><header class="mp-hero"><div class="shell mp-hero-grid"><div><p class="eyebrow">Platform</p><h1>The control plane for <span class="gradient-text">AI-written code.</span></h1><p class="lede">Mault governs agent actions before they become production risk, without slowing developers or replacing their tools.</p><div class="hero-actions"><a class="button" href="/pilot/">Start a pilot</a><a class="button button-secondary" href="/how-it-works/">How it works</a></div></div><aside class="mp-panel"><p class="eyebrow">One governed action</p><h2>Identity → intent → policy → evidence</h2><ul class="mp-list"><li>Authenticated developer</li><li>Attributed coding agent</li><li>Evaluated affected scope</li><li>Deterministic decision</li><li>Sealed execution record</li></ul></aside></div></header><section class="section mp-band"><div class="shell"><p class="eyebrow">Core capabilities</p><h2 class="mp-section-title">Governance that executes.</h2><div class="mp-grid-3">{capabilities.map(([title,copy],i)=><article class="mp-card" data-reveal><span>0{i+1}</span><h3>{title}</h3><p>{copy}</p></article>)}</div></div></section><section class="section"><div class="shell"><div class="section-head"><div><p class="eyebrow">Built into the workflow</p><h2>Control at every boundary.</h2></div><p>Apply policy while the agent works, before file writes, at commit, and before production deployment.</p></div><div class="mp-grid-2"><article class="mp-card"><span>Developer experience</span><h3>Fast feedback, not another queue</h3><p>Developers receive actionable decisions inside their existing workflow, with the exact policy and affected scope explained.</p></article><article class="mp-card"><span>Security experience</span><h3>Proof without reconstruction</h3><p>Security and compliance teams receive attributable evidence automatically instead of rebuilding a narrative after an incident.</p></article></div></div></section><section class="cta"><div class="shell cta-box"><p class="eyebrow">Deploy safely</p><h2>Scale agents without scaling risk.</h2><a class="button" href="/pilot/">Explore the 45-day pilot</a></div></section></SiteLayout>
