import SiteLayout from '../layouts/SiteLayout.astro'; import '../styles/marketing-pages.css';
const rows=[['Real-time structure analysis','Included','Included'],['Architectural drift detection','Included','Included'],['VS Code findings panel','Included','Included'],['Copy-ready remediation prompts','Included','Included'],['Automatic policy enforcement','—','Included'],['Non-compliant commit blocking','—','Included'],['Security and hallucination guard','—','Included'],['Early access to new controls','—','Included']];
---
<SiteLayout title="Mault Pricing | Core, Pro, and Enterprise" description="Compare Mault Core detection, Pro production enforcement, and tailored enterprise governance." canonical="/pricing/"><header class="mp-hero"><div class="shell"><p class="eyebrow">Pricing</p><h1 class="display">Start with visibility.<br/><span class="gradient-text">Upgrade to enforcement.</span></h1><p class="lede">Use Core to understand structural risk. Use Pro when your standards must execute automatically.</p></div></header><section class="section"><div class="shell mp-grid-2"><article class="price-card"><p class="eyebrow">Mault Core</p><h2>Detection for every developer.</h2><div class="price">$0 <small>/ developer</small></div><ul><li>Continuous project analysis</li><li>Architectural drift detection</li><li>VS Code findings panel</li><li>Copy-ready remediation prompts</li><li>Dependency health visibility</li></ul><a class="button button-secondary" href="/docs/ai-coder-guide/">Read the setup guide</a></article><article class="price-card featured"><p class="eyebrow">Mault Pro</p><h2>Production enforcement.</h2><div class="price">Custom <small>/ team</small></div><ul><li>Everything in Core</li><li>Automatic commit enforcement</li><li>Security and hallucination guard</li><li>Production-readiness activation</li><li>Early access to new controls</li></ul><a class="button" href="/pilot/">Start a pilot</a></article></div></section><section class="section mp-band"><div class="shell"><p class="eyebrow">Feature comparison</p><h2 class="mp-section-title">Choose the control level you need.</h2><div class="mp-table"><table><thead><tr><th>Capability</th><th>Core</th><th>Pro</th></tr></thead><tbody>{rows.map(row=><tr>{row.map(cell=><td>{cell}</td>)}</tr>)}</tbody></table></div></div></section><section class="section"><div class="shell mp-grid-2"><article class="mp-card"><span>Pro activation</span><h3>Production-readiness kit</h3><p>A guided setup distills Mault’s engineering principles, including Hexagonal Architecture and Mock Tax controls, into an approximately 30-minute activation workflow.</p></article><article class="mp-card"><span>Enterprise</span><h3>Organization-wide governance</h3><p>Custom policies, team-level enforcement, CI/CD alignment, onboarding, and dedicated support for larger engineering organizations.</p><a href="/enterprise/" style="color:var(--green)">Explore Enterprise →</a></article></div></section></SiteLayout>
